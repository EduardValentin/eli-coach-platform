{
  "name": "@eli-coach-platform/db",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "dependencies": {
    "@eli-coach-platform/domain": "workspace:*",
    "drizzle-kit": "catalog:",
    "drizzle-orm": "catalog:",
