{
  "name": "eli-coach-platform",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=24.14.1 <25"
  },
  "scripts": {
    "build": "pnpm --filter @eli-coach-platform/platform build",
    "db:bootstrap:local": "./packages/db/scripts/bootstrap-local.sh",
    "db:generate": "pnpm --filter @eli-coach-platform/db run db:generate",
    "db:migrate": "pnpm --filter @eli-coach-platform/db run db:migrate",
    "db:setup:local": "./packages/db/scripts/setup-local.sh",
    "lint": "eslint apps packages --ext .ts,.tsx",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "vitest run",
    "dev": "pnpm --filter @eli-coach-platform/platform dev",
    "dev:platform": "pnpm --filter @eli-coach-platform/platform dev",
    "dev:all": "./scripts/dev/start_local_stack.sh",
    "docker:local:up": "docker compose -f docker-compose.local.yml up -d",
    "docker:local:down": "docker compose -f docker-compose.local.yml down",
    "secrets:local:prepare": "./scripts/secrets/prepare_local_secret_set.sh eli-coach-platform"
  },
  "devDependencies": {
    "happy-dom": "catalog:",
    "@testing-library/jest-dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@typescript-eslint/parser": "catalog:",
    "@types/node": "catalog:",
    "@testcontainers/postgresql": "catalog:",
    "eslint": "catalog:",
    "eslint-plugin-jsx-a11y": "catalog:",
    "globals": "catalog:",
    "testcontainers": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
